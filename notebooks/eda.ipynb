    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"## 1.1 Monthly Sales Trend\\n\",\n",
    "    \"**Business Question:** How has the order volume evolved on a monthly basis over the past year?\"\n",
    "   ],\n",
    "   \"id\": \"296c3f3361a2900b\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-07-07T18:29:05.556090Z\",\n",
    "     \"start_time\": \"2026-07-07T18:29:05.051271Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"query = \\\"\\\"\\\"\\n\",\n",
    "    \"SELECT\\n\",\n",
    "    \"    strftime('%Y-%m', o.order_purchase_timestamp) AS month,\\n\",\n",
    "    \"    SUM(oi.price) AS revenue\\n\",\n",
    "    \"FROM orders o\\n\",\n",
    "    \"JOIN order_items oi on oi.order_id = o.order_id\\n\",\n",
    "    \"WHERE order_status = 'delivered'\\n\",\n",
    "    \"      AND month NOT IN ('2018-09', '2018-10')\\n\",\n",
    "    \"GROUP BY month\\n\",\n",
    "    \"ORDER BY month ASC;\\n\",\n",
    "    \"\\\"\\\"\\\"\\n\",\n",
    "    \"df_trend = pd.read_sql_query(query, engine)\\n\",\n",
    "    \"df_trend.head()\"\n",
    "   ],\n",

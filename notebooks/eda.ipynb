    "   \"source\": [\n",
    "    \"\\n\",\n",
    "    \"df_filtered = df_logistics[df_logistics['delivery_time_days'] <= 90]\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"state_order = df_filtered.groupby('customer_state')['delivery_time_days'].median().sort_values().index\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.figure(figsize=(14, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.boxplot(\\n\",\n",
    "    \"    data=df_filtered,\\n\",\n",
    "    \"    x='customer_state',\\n\",\n",
    "    \"    y='delivery_time_days',\\n\",\n",
    "    \"    order=state_order,\\n\",\n",
    "    \"    hue='customer_state',\\n\",\n",
    "    \"    legend=False,\\n\",\n",
    "    \"    palette=\\\"Blues_r\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.title('Distribution of Delivery Time by Brazilian State', fontsize=16, pad=15)\\n\",\n",
    "    \"plt.xlabel('Customer State', fontsize=12)\\n\",\n",
    "    \"plt.ylabel('Delivery Time (Days)', fontsize=12)\\n\",\n",
    "    \"plt.xticks(rotation=45)\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"\\n\",\n",

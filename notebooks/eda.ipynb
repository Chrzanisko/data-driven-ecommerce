    "   \"source\": [\n",
    "    \"plt.figure(figsize=(14, 7))\\n\",\n",
    "    \"df_long = df_freight.melt(\\n\",\n",
    "    \"    id_vars=['category'],\\n\",\n",
    "    \"    value_vars=['avg_product_value', 'avg_freight_cost'],\\n\",\n",

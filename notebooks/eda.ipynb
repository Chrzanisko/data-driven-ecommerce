    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"df_long['cost_type'] = df_long['cost_type'].map({\\n\",\n",
    "    \"    'avg_product_value': 'Average Product Value',\\n\",\n",
    "    \"    'avg_freight_cost': 'Average Freight Cost'\\n\",\n",
    "    \"})\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax = sns.barplot(\\n\",\n",

    "    \"    palette=\\\"Blues_r\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.title('Freight vs. Product Value by Top 10 Categories', fontsize=15, pad=20, weight='bold')\\n\",\n",
    "    \"plt.xlabel('Product Category', fontsize=12, labelpad=10)\\n\",\n",
    "    \"plt.ylabel('Value in BRL', fontsize=12, labelpad=10)\\n\",\n",

    "    \"    ax=ax1\\n\",\n",
    "    \")\\n\",\n",
    "    \"ax1.set_title('Top 10 Categories by Order Volume (Units Sold)', fontsize=14, pad=15)\\n\",\n",
    "    \"ax1.set_xlabel('Units Sold', fontsize=12)\\n\",\n",
    "    \"ax1.set_ylabel('Product Category', fontsize=12)\\n\",\n",
    "    \"ax1.grid(axis='x', linestyle='--', alpha=0.2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sns.barplot(\\n\",\n",
    "    \"    x='total_revenue',\\n\",\n",
    "    \"    y='category',\\n\",\n",
    "    \"    hue='category',\\n\",\n",
    "    \"    data=df_revenue,\\n\",\n",
    "    \"    palette='Blues_r',\\n\",\n",
    "    \"    legend=False,\\n\",\n",
    "    \"    ax=ax2\\n\",\n",
    "    \")\\n\",\n",
    "    \"ax2.set_title('Top 10 Categories by Total Revenue (BRL)', fontsize=14, pad=15)\\n\",\n",
    "    \"ax2.set_xlabel('Total Revenue (BRL)', fontsize=12)\\n\",\n",
    "    \"ax2.set_ylabel('Product Category', fontsize=12)\\n\",\n",
    "    \"ax2.grid(axis='x', linestyle='--', alpha=0.2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"ax2.xaxis.set_major_formatter(ticker.FuncFormatter(lambda x, pos: f'{x*1e-6:.1f}M' if x >= 1e6 else f'{x*1e-3:.0f}k'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.savefig(os.path.join(images_dir, 'Top_Product_Categories.png'), dpi=300)\\n\",\n",
    "    \"plt.show()\"\n",
    "   ],\n",
    "   \"id\": \"938368b3fb44605b\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"<Figure size 1600x800 with 2 Axes>\"\n",
    "      ],\n",
    "      \"image/png\": \"\"\n",
